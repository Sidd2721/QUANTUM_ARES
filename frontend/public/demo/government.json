    },
    {
      "source": "aadhaar_service",
      "target": "citizen_records",
      "auth_required": true,
      "mfa_required": false,
      "tls_enforced": false,
      "access_scope": "FULL"
    },
    {
      "source": "citizen_portal",
      "target": "tax_records",
      "auth_required": false,
      "mfa_required": false,
      "tls_enforced": false,
      "access_scope": "FULL"
    },
    {
      "source": "internal_admin",
      "target": "citizen_records",
      "auth_required": true,
      "mfa_required": false,
      "tls_enforced": true,
      "access_scope": "FULL"
    }
  ]
}
